{
  "name": "livre",
  "productName": "Livre",
  "version": "0.9.0",
  "description": "Un lecteur qui transforme vos PDF en véritable expérience de lecture — texture papier, typographie soignée, bionic reading.",
  "author": "Simon Courtois <simoncrts@protonmail.com>",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "make-icon": "electron tools/make-icon.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/literata": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/opendyslexic": "^5.2.5",
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.simoncrts.livre",
    "productName": "Livre",
    "publish": [
      {
        "provider": "github",
        "owner": "Simon256px",
        "repo": "livre"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/*.map"
    ],
    "asarUnpack": [
      "node_modules/tesseract.js/**",
      "node_modules/tesseract.js-core/**",
      "src/renderer/vendor/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "Livre-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "description": "Document PDF",
        "role": "Viewer"
      },
      {
        "ext": "epub",
        "description": "Livre EPUB",
        "role": "Viewer"
      }
    ]
  }
}
